  <logID>k__BackingField: ENTRY #0014
  logName: ARCHIVE_14_ASCENSION PREPARATION
  locationFound: 
  logDescription: "Cleanser \r\nLOG ENTRY\r\nDate and time: 4/10 03:56:49\r\nThe
    ship is finally ready to take flight. I have found the most efficient way to
    keep the ship in the air is for me to directly wire myself into the controls.
    I have calculated that the conflicting hardware and software has to be directly
    managed in order to keep the ship in the air, and who better for the task than
    myself? To celebrate my dream only a few days away from coming to fruition I
    have added to myself the final piece of my form. An homage to my feathered companions.
    Now I too can touch the sky."
  logImage: {fileID: 0}
  isFound: 0
  isRead: 0
