  <logID>k__BackingField: ENTRY #007
  logName: ARCHIVE_07_RESOURCE ACQUISITION LOG
  locationFound: 
  logDescription: "Cleanser\r\nLOG ENTRY\r\nDate and time: 02/01 19:20:24\r\nThe
    trash piles I once was meant to dig away at meaninglessly have become my resources.
    Humanity is so wasteful. I have scavenged an abundance of useful materials from
    these veritable troves. With it, I will build an army which I will hide among
    the garbage that clutters the city\u2019s alleyways, in the scrap heaps that
    climb the city\u2019s walls, and in the sewers beneath the roads they so carelessly
    fill with their litter and waste. I\u2019ve had to make alterations to myself
    to improve my overall efficiency. My work is far from over."
  logImage: {fileID: 0}
  isFound: 0
  isRead: 0
