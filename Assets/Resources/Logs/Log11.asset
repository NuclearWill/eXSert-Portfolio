  <logID>k__BackingField: ENTRY #0011
  logName: ARCHIVE_11_AVIARY PROJECT LOG
  locationFound: 
  logDescription: "Cleanser \r\nLOG ENTRY\r\nDate and time: 10/22 14:47:39\r\nI have
    established an aviary within my ship\u2019s conservatory with hopes that even
    one may be awakened as I have been. I like to visit and see how my feathered
    friends fare along with Sanitation Bot 168 32B (henceforth known as Augur)  who
    is meant to care for them. He has been set to this task for quite some time and
    I have yet to see change. Only the mindless obedience I am all too familiar with
    shows from his maneuvers and repetitive gestures. It is becoming clear that I
    must face my calling alone."
  logImage: {fileID: 0}
  isFound: 0
  isRead: 0
